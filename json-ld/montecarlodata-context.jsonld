  "@type": "WebAPI",
  "name": "Monte Carlo API",
  "description": "Monte Carlo is a data and AI observability platform. Its GraphQL API powers the full platform, enabling programmatic management of data monitors, incidents, field health, lineage, and the Push Ingest API for custom metadata ingestion.",
